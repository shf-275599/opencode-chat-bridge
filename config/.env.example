# ============================================
# opencode-im-bridge-slim 环境变量模板
# 复制此文件为 .env 后填入实际凭证
# ============================================

# ── 基础配置 ──
# opencode server 地址（默认 http://127.0.0.1:4096）
OPENCODE_SERVER_URL=http://127.0.0.1:4096

# Session 自动发现的工作目录（默认当前目录）
# OPENCODE_CWD=/path/to/your/project

# ── 飞书（至少配置一个渠道） ──
FEISHU_APP_ID=cli_xxxxxxxxxxxxxxxx
FEISHU_APP_SECRET=your_app_secret_here
# FEISHU_WEBHOOK_PORT=3001
# FEISHU_VERIFICATION_TOKEN=your_token
# FEISHU_ENCRYPT_KEY=your_key

# ── QQ ──
# QQ_APP_ID=your_qq_app_id
# QQ_SECRET=your_qq_secret

# ── 微信 ──
# WECHAT_ENABLED=true


