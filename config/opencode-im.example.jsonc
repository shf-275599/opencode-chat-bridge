{
  // 飞书应用配置
  "feishu": {
    // 飞书开放平台 App ID（环境变量: FEISHU_APP_ID）
    "appId": "${FEISHU_APP_ID}",

    // 飞书开放平台 App Secret（环境变量: FEISHU_APP_SECRET）
    "appSecret": "${FEISHU_APP_SECRET}",

    // 事件订阅验证 Token（环境变量: FEISHU_VERIFICATION_TOKEN）
    "verificationToken": "${FEISHU_VERIFICATION_TOKEN}",

    // Webhook 服务端口（默认: 3001）
    "webhookPort": 3001,

    // 事件加密密钥（可选）
    "encryptKey": "${FEISHU_ENCRYPT_KEY}"
  },

  // QQ 机器人配置
  "qq": {
    // QQ 开放平台 App ID（环境变量: QQ_APP_ID）
    "appId": "${QQ_APP_ID}",
  
    // QQ 开放平台 App Secret（环境变量: QQ_SECRET）
    "secret": "${QQ_SECRET}",
  
    // 是否启用沙箱模式（默认: false）
    "sandbox": false
  },

  // 微信机器人配置
  "wechat": {
    // 是否启用微信渠道（环境变量: WECHAT_ENABLED）
    "enabled": true,
  
    // 扫码登录会话持久化路径
    "sessionFile": "./data/wechat-session.json"
  },

  // 默认使用的 opencode agent 名称，需与 opencode 配置中的 agent 一致
  // 常见值: "build"、"claude"、"code"
  "defaultAgent": "OpenCode-Builder",

  // SQLite 数据库存放目录
  "dataDir": "./data",

  // 进度卡片更新防抖配置
  "progress": {
    "debounceMs": 500,
    "maxDebounceMs": 3000
  }

  // 可选：定时任务配置
  // "cron": {
  //   "jobs": [
  //     {
  //       "name": "每日站会",
  //       "schedule": "0 9 * * 1-5",
  //       "prompt": "早上好，请总结今日待办事项。",
  //       "chatId": "oc_xxxxxxxxxxxxxxxx"
  //     }
  //   ]
  // }
}
